{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A farmer community post with text, image, and voice capabilities",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique post identifier" },
        "author": { "type": "string", "description": "Display name of the author" },
        "authorUid": { "type": "string", "description": "The firebase auth UID of the author" },
        "isVerified": { "type": "boolean", "description": "Whether the farmer is an officially verified grower" },
        "content": { "type": "string", "description": "Post narrative content in English, Kannada, or Hindi" },
        "image": { "type": "string", "description": "Base64 payload or public URL string represent of crop sample" },
        "voiceUrl": { "type": "string", "description": "Optional recorded voice message base64 or URL data" },
        "voiceCaption": { "type": "string", "description": "Optional captions generated for the voice recording" },
        "likes": { "type": "number", "description": "Total count of liked interactions" },
        "district": { "type": "string", "description": "The district filter scope e.g., Kolar, Raichur, Mandya" },
        "village": { "type": "string", "description": "Optional village level scope of the discussion" },
        "category": { "type": "string", "description": "Discussion category e.g., disease, weather, crop_update" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server time of creation" }
      },
      "required": ["id", "author", "authorUid", "content", "likes", "district", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A reply on a direct community post with language settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "authorUid": { "type": "string" },
        "content": { "type": "string" },
